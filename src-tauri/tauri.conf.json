{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcreve",
  "version": "0.1.0",
  "identifier": "br.com.transcreve.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Transcreve",
        "width": 1100,
        "height": 740,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Hebert Almeida",
    "homepage": "https://github.com/Hebert-Almeida/transcreve",
    "shortDescription": "Transcrição e análise de áudios de pesquisa — 100% local e offline.",
    "longDescription": "Aplicativo desktop que transcreve áudios longos (entrevistas, grupos focais) e os analisa qualitativa e quantitativamente, sem enviar nenhum dado para a internet.",
    "copyright": "© 2026 Hebert Almeida — GPL-3.0",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/transcreve-sidecar.exe",
      "binaries/_internal/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "./windows/hooks.nsi",
        "languages": ["PortugueseBR", "English"],
        "displayLanguageSelector": false
      }
    }
  }
}
